nextflow_pipeline {

    name "Test pipeline bismark"
    script "../main.nf"
    tag "pipeline"
    profile "test,docker"
    test("bismark-fastq") {

        when {
            params {
                outdir = "$outputDir"
                skip_rastair = true
                input = "${projectDir}/assets/samplesheet_fastq.csv"
            }
        }

        then {
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}', '*.snap', 'bismark/methylation_calls/**'])
                .sort()
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
                .sort { a, b -> a.name <=> b.name }
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    stable_name,
                    stable_path
                ).match() }
            )
        }
    }
}
