// Load modules configuration
process {
    withName: FASTP_TRIM {
        ext.args = { [
            params.fastp_length_required ? "--length_required ${params.fastp_length_required}" : null
        ].findAll{ it }.join(' ') }
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/fastp" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: BSBOLT_ALIGN {
        // Skip pairing and mate rescue for small datasets to work with test data
        ext.skip_pairing = true
        ext.skip_mate_rescue = true
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/bsbolt/alignment" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: BSBOLT_CALL_METHYLATION {
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/bsbolt/methylation_calls" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: BSBOLT_AGGREGATE_MATRIX {
        // Aggregate matrix options
        ext.min_coverage = 10
        ext.min_sample = 0.8
        ext.cgonly = false
        ext.count_matrix = false
        ext.verbose = false
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/bsbolt/aggregate_matrix" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: GATKSPARK_MARKDUPLICATES {
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/gatk/deduplicated" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: SAMTOOLS_MARKDUP {
        // Disable proper pair check for small datasets with single-end or improper pairs
        ext.args_fixmate = '-p -m'
        ext.args_sort_threads = '-@ 2'
        ext.args_markdup = ''
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/samtools/deduplicated" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }

    withName: SAMTOOLS_MERGE {
        publishDir = [
            enabled: true,
            path: { "${params.outdir}/merged_alignment" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename == 'versions.yml' ? null : filename }
        ]
    }
    withName: RASTAIR_CALL {
        ext.args = [
            params.trim_OT ?: '0,0,10,0',
            params.trim_OB ?: '0,0,10,0'
        ].join(' ').trim()
        publishDir = [
            [
                path: { "${params.outdir}/rastair/call" },
                mode: params.publish_dir_mode,
                pattern: "*.txt"
            ],
            [
                path: { "${params.outdir}/rastair/call" },
                mode: params.publish_dir_mode,
                pattern: "*.gz"
            ]
        ]
    }
    withName: RASTAIR_MBIAS {
        publishDir = [
            [
                path: { "${params.outdir}/rastair/mbias" },
                mode: params.publish_dir_mode,
                pattern: "*.txt"
            ]
        ]
    }
    withName: RASTAIR_MBIASPARSER {
        publishDir = [
            [
                path: { "${params.outdir}/rastair/mbiasparser" },
                mode: params.publish_dir_mode,
                pattern: "*rastair_mbias_processed*"
            ]
        ]
    }
    withName: RASTAIR_METHYLKIT {
        publishDir = [
            [
                path: { "${params.outdir}/rastair/methylkit" },
                mode: params.publish_dir_mode,
                pattern: "*.txt.gz"
            ]
        ]
    }
}
